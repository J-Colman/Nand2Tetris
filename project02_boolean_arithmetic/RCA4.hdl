/*	4-bit Ripple Carry Adder:
    Adds two 4-bit numbers, propagating carry out.  */
CHIP RCA4 {
	IN a[4], b[4], cin;
	OUT out[4], cout;
	PARTS:
    FullAdder(a=a[0], b=b[0], c=cin, sum=out[0], carry=w1);
    FullAdder(a=a[1], b=b[1], c=w1, sum=out[1], carry=w2);
    FullAdder(a=a[2], b=b[2], c=w2, sum=out[2], carry=w3);
    FullAdder(a=a[3], b=b[3], c=w3, sum=out[3], carry=cout);
}
