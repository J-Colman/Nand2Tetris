/*	16-Bit Carry Lookahead Adder:
    Adds two 16-bit numbers using four chained CLA4 blocks.
    Carries still ripple between blocks.
    Overflow is ignored.    */
CHIP CLA16 {
	IN a[16], b[16];
	OUT out[16];
	PARTS:
    CLA4(a=a[0..3], b=b[0..3], cin=false, out=out[0..3], cout=c1);
    CLA4(a=a[4..7], b=b[4..7], cin=c1, out=out[4..7], cout=c2);
    CLA4(a=a[8..11], b=b[8..11], cin=c2, out=out[8..11], cout=c3);
    CLA4(a=a[12..15], b=b[12..15], cin=c3, out=out[12..15], cout=overflow);
}
